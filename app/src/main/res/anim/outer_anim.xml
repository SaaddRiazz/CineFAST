<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android">

    <scale
        android:fromXScale="1000dp"
        android:toXScale="135dp"
        android:fromYScale="1000dp"
        android:toYScale="135dp"
        android:pivotX="54%"
        android:pivotY="50%"
        android:duration="1500"/>
    <rotate
        android:fromDegrees="0"
        android:toDegrees="360"
        android:pivotX="54%"
        android:pivotY="50%"
        android:duration="3000"/>
</set>